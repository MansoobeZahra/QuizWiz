<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!-- =====================================================
       UPDATE the Data Source to match your SQL Server name.
       Common values: (local)  .\SQLEXPRESS  DESKTOP-XXXX\SQLEXPRESS
       ===================================================== -->
  <connectionStrings>
    <add name="QuizWizDB"
         connectionString="Data Source=(local);Initial Catalog=QuizWizDB;Integrated Security=True;MultipleActiveResultSets=True;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.web>
    <compilation debug="true" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" maxRequestLength="10240" />

    <!-- Session timeout: 60 minutes -->
    <sessionState timeout="60" />

    <!-- Custom errors: off during development -->
    <customErrors mode="Off" />

    <!-- Default page config removed from here (already exists in system.webServer) -->

    <pages controlRenderingCompatibilityVersion="4.0" />
  </system.web>

  <system.webServer>
    <defaultDocument>
      <files>
        <clear />
        <add value="Login.aspx" />
      </files>
    </defaultDocument>
    <modules runAllManagedModulesForAllRequests="true" />
    <staticContent>
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>
  </system.webServer>

</configuration>
